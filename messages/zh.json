  "messages": {
    "1": {
      "content": "心即一切。你所思，即你所是。",
      "source": "佛陀"
    },
    "2": {
      "content": "不沉溺于过去，不幻想未来，将心念集中于当下此刻。",
      "source": "佛陀"
    },
    "3": {
      "content": "平静来自内心，不要向外寻求。",
      "source": "佛陀"
    },
    "4": {
      "content": "苦之根源在于执著。",
      "source": "佛陀"
    },
    "5": {
      "content": "初学者的心中有无限可能，而专家的心中却所剩无几。",
      "source": "铃木俊隆"
    },
    "6": {
      "content": "悟道前，砍柴挑水；悟道后，砍柴挑水。",
      "source": "禅语"
    },
    "7": {
      "content": "当你意识到什么都不缺少时，整个世界就属于你了。",
      "source": "老子"
    },
    "8": {
      "content": "无论身在何处，全然临在其中。",
      "source": "埃克哈特·托利"
    },
    "9": {
      "content": "当下时刻是我们唯一能够拥有的时刻，它是通往所有时刻的门。",
      "source": "一行禅师"
    },
    "10": {
      "content": "若你明白，事物就是如此；若你不明白，事物依然如此。",
      "source": "禅语"
    },
    "11": {
      "content": "微笑，呼吸，慢慢走。",
      "source": "一行禅师"
    },
    "12": {
      "content": "学佛即学己，学己即忘己。",
      "source": "道元"
    },
    "13": {
      "content": "障碍即是道路。",
      "source": "禅语"
    },
    "14": {
      "content": "知者不言，言者不知。",
      "source": "老子"
    },
    "15": {
      "content": "你无法走上这条路，直到你自己成为这条路。",
      "source": "佛陀"
    }
  }
}
